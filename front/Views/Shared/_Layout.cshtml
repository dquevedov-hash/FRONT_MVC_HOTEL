<!DOCTYPE html>
<html lang="es" data-rol="@(Context.Session.GetString("Rol") ?? "")">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HotelOS — @ViewData["Title"]</title>
  <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@{
  var username = Context.Session.GetString("Username");
  var rol      = Context.Session.GetString("Rol") ?? "";
  var ctrl     = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

  bool esAdmin      = rol == "Administrador";
  bool esSupervisor = rol == "Supervisor";
  bool esRecepcion  = rol == "Recepcionista";

  // Badge CSS class por rol
  var rolBadgeClass = rol switch {
    "Administrador" => "admin",
    "Supervisor"    => "supervisor",
    "Recepcionista" => "recepcion",
    _               => "admin"
  };

  // Inicial del avatar
  var avatarLetra = username?.Substring(0,1).ToUpper() ?? "U";
}

@if (username != null)
{
  <div class="layout">

    <!-- ── SIDEBAR ──────────────────────────────────────── -->
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-name">HOTEL<span>OS</span></div>
        <div class="brand-sub">v2.0 · MVC · Razor</div>
        <div class="rol-badge @rolBadgeClass">@rol</div>
      </div>

      <nav class="nav">

        <!-- Dashboard: todos -->
        <a class="nav-link @(ctrl=="Home"?"active":"")"
           asp-controller="Home" asp-action="Index">
          <span class="nav-icon">⊞</span> Dashboard
        </a>

        <!-- GESTIÓN -->
        @if (esAdmin || esSupervisor || esRecepcion)
        {
          <div class="nav-section">Gestión</div>
        }
        @if (esAdmin)
        {
          <a class="nav-link @(ctrl=="Hotel"?"active":"")"
             asp-controller="Hotel" asp-action="Index">
            <span class="nav-icon">🏨</span> Hoteles
          </a>
        }
        @if (esAdmin || esSupervisor || esRecepcion)
        {
          <a class="nav-link @(ctrl=="Habitacion"?"active":"")"
             asp-controller="Habitacion" asp-action="Index">
            <span class="nav-icon">🛏</span> Habitaciones
          </a>
          <a class="nav-link @(ctrl=="Reservacion"?"active":"")"
             asp-controller="Reservacion" asp-action="Index">
            <span class="nav-icon">📋</span> Reservaciones
          </a>
        }

        <!-- PERSONAS -->
        @if (esAdmin || esSupervisor || esRecepcion)
        {
          <div class="nav-section">Personas</div>
          <a class="nav-link @(ctrl=="Cliente"?"active":"")"
             asp-controller="Cliente" asp-action="Index">
            <span class="nav-icon">👤</span> Clientes
          </a>
        }
        @if (esAdmin)
        {
          <a class="nav-link @(ctrl=="Empleado"?"active":"")"
             asp-controller="Empleado" asp-action="Index">
            <span class="nav-icon">👔</span> Empleados
          </a>
        }

        <!-- SISTEMA -->
        <div class="nav-section">Sistema</div>
        @if (esAdmin || esSupervisor)
        {
          <a class="nav-link @(ctrl=="Reportes"?"active":"")"
             asp-controller="Reportes" asp-action="Index">
            <span class="nav-icon">📊</span> Reportes
          </a>
        }
        @if (esAdmin)
        {
          <a class="nav-link @(ctrl=="Usuario"?"active":"")"
             asp-controller="Usuario" asp-action="Index">
            <span class="nav-icon">🔑</span> Usuarios
          </a>
        }

      </nav>

      <!-- User chip -->
      <div class="sidebar-footer">
        <div class="user-chip">
          <div class="user-avatar">@avatarLetra</div>
          <div class="user-info">
            <div class="user-name">@username</div>
            <div class="user-role">@rol</div>
          </div>
          <a asp-controller="Home" asp-action="Logout"
             class="logout-btn" title="Cerrar sesión">⏻</a>
        </div>
      </div>
    </aside>

    <!-- ── MAIN ─────────────────────────────────────────── -->
    <main class="main">
      <div class="topbar">
        <div class="page-title">@ViewData["Title"]</div>
        <div class="topbar-right">
          <span class="topbar-user">@username</span>
        </div>
      </div>

      <div class="content">
        <!-- Alertas TempData -->
        @if (TempData["Success"] != null)
        {
          <div class="alert alert-success">✔ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
          <div class="alert alert-danger">✖ @TempData["Error"]</div>
        }

        <div class="page-enter">
          @RenderBody()
        </div>
      </div>
    </main>

  </div>

  <!-- Toast container -->
  <div class="toast-stack" id="toastStack"></div>

  <script>
    // Función toast reutilizable en todas las vistas
    function toast(msg, type = 'ok') {
      const el = document.createElement('div');
      el.className = 'toast';
      el.innerHTML = `<div class="toast-dot ${type}"></div><span>${msg}</span>`;
      document.getElementById('toastStack').prepend(el);
      setTimeout(() => el.remove(), 3200);
    }
  </script>
}
else
{
  @RenderBody()
}

</body>
</html>
